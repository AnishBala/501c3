# Root example env settings for local development.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_NAME=grant-platform-backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/grant_platform
REDIS_URL=redis://redis:6379/0

# Worker
WORKER_REDIS_URL=redis://redis:6379/0
